-- ==
-- input { [1i64,2i64,3i64] [10i64,20i64] }
-- output {
--   [
--     [[1i64,10i64,11i64], [1i64,20i64,21i64]],
--     [[2i64,10i64,12i64], [2i64,20i64,22i64]],
--     [[3i64,10i64,13i64], [3i64,20i64,23i64]]
--   ]
-- }
entry main (xs: []i64) (ys: []i64) =
  map (\x ->
         map (\y -> [x, y, x + y]) ys)
      xs